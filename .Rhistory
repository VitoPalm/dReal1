full_formula <- y_IQ ~ x1_ISO + x2_T + x3_MP + x4_CF + x5_F + x6_GSI + x7_UA +
I(x1_ISO^2) + I(x2_T^2) + I(x3_MP^2) + I(x4_CF^2) +
I(x5_F^2) + I(x6_GSI^2) + I(x7_UA^2) +
(x1_ISO + x2_T + x3_MP + x4_CF + x5_F + x6_GSI + x7_UA)^2
null_model <- lm(y_IQ ~ 1, data = twist)
fff <- step(
null_model,
scope = list(
lower = ~ 1,
upper = formula(full_formula)
),
direction = "both",
trace = 1,
k = log(n)
)
summary(fff)
