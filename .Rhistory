fit01 = fit01,
fit001 = fit001,
fit002 = fit002,
fit0001 = fit0001,
fit0002 = fit0002
)
par(mfrow = c(3, 2))
for (name in names(fits)) {
cook <- cooks.distance(fits[[name]])
threshold <- 4 / nobs(fits[[name]])
plot(cook,
type = "h",
main = name,
ylim = c(0, 0.13),
xlab = "Obs. number",
ylab = "Cook's distance")
abline(h = threshold, col = "red", lty = 2)
influential <- which(cook > threshold)
text(influential, cook[influential],
labels = influential,
pos = 3,
cex = 0.8)
}
AIC(fit1, fit01, fit001, fit002, fit0001, fit0002)
BIC(fit1, fit01, fit001, fit002, fit0001, fit0002)
